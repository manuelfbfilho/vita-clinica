# ═══════════════════════════════════════════════════════════════
# Vita Clínica — Variáveis de Ambiente
# Copie: cp .env.example .env   e preencha os valores reais
# NUNCA commite o arquivo .env
# ═══════════════════════════════════════════════════════════════

# ── Banco de Dados ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/vitaclinica
DB_USERNAME=vitaclinica_user
DB_PASSWORD=vitaclinica_pass

# ── JWT ─────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=substitua-por-uma-chave-aleatoria-de-minimo-64-caracteres
JWT_EXPIRATION=86400000

# ── Email (Resend) ──────────────────────────────────────────────
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_sua_chave_aqui
EMAIL_REMETENTE=contato@vitaclinica.com.br

# ── Frontend ────────────────────────────────────────────────────
FRONTEND_URL=https://vitaclinica.vercel.app

# ── Oracle (opcional) ───────────────────────────────────────────
# ORACLE_URL=jdbc:oracle:thin:@localhost:1521/XEPDB1
# ORACLE_USERNAME=vitaclinica
# ORACLE_PASSWORD=senha
